<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="cs_rover">
    <static>false</static>

    <!-- 主体底盘 link -->
    <link name="base_link">
      <pose>0 0 0.20 0 0 0</pose>
      <inertial>
        <mass>10</mass>
        <inertia>
          <ixx>0.2604</ixx><iyy>0.5854</iyy><izz>0.7417</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="base_visual">
        <geometry>
          <mesh>
            <uri>model://cs_rover_charge/meshes/body.dae</uri>
            <!-- 可选缩放比例（如需调整大小） -->
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>      <!-- 环境光，较亮 -->
          <diffuse>0.2 0.2 0.2 1</diffuse>      <!-- 主颜色，浅灰，接近碳纤维但不太深 -->
          <specular>0.4 0.4 0.4 1</specular>    <!-- 高光，增强金属质感 -->
          <emissive>0 0 0 1</emissive>          <!-- 无自发光 -->
        </material>
      </visual>
      <collision name="base_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box><size>0.8 0.5 0.25</size></box>
        </geometry>
      </collision>
    </link>

<!-- imu -->
    <link name="imu_link">
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00002</iyy>
          <iyz>0</iyz>
          <izz>0.00002</izz>
        </inertia>
      </inertial>
      <sensor name="imu_sensor" type="imu">
        <pose>0 0 0 3.141593 0 0</pose> <!-- Relative position of IMU on the link -->
        <always_on>1</always_on>
        <imu>
          <update_rate>1000.0</update_rate> <!-- IMU Update Rate -->
          <orientation_frame>body</orientation_frame> <!-- Orientation frame, can be 'world' or 'body' -->
          <noise>
            <angular_velocity>0.01</angular_velocity> <!-- Noise in rad/s -->
            <linear_acceleration>0.01</linear_acceleration> <!-- Noise in m/s² -->
          </noise>
        </imu>
      </sensor>
    </link>

    <joint name='imu_joint' type='revolute'>
      <child>imu_link</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>0</lower>
          <upper>0</upper>
          <effort>0</effort>
          <velocity>0</velocity>
        </limit>
        <dynamics>
          <damping>1.0</damping>
        </dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>

    <!-- Camera -->
    <link name="camera_link">
      <pose> -0.3 0 .2 0 0 3.14</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>.10</ixx>
          <iyy>.10</iyy>
          <izz>.30</izz>
        </inertia>
      </inertial>
      <collision name='collision'>
        <geometry>
          <box>
            <size>0.03 0.2 0.03</size>
          </box>
        </geometry>
      </collision>

      <visual name='visual'>
        <geometry>
          <box>
            <size>0.03 0.2 0.03</size>
          </box>
        </geometry>
        
        <material>
          <ambient>1 0 0 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
          <emissive>0 0 0 0</emissive>
        </material>
      </visual>

      <!-- camera plugin -->
      <!-- refered to realsense rgb camera profile -->
      <sensor type="camera" name="camera1">
        <update_rate>10.0</update_rate>
        <camera name="head">
          <horizontal_fov>1.204</horizontal_fov>
          <image>
            <!-- <width>1920</width>
              <height>1080</height> -->
              <!-- Will use a lower res than the actual camera resolution,
              while maintaining the same ratio. This is to assist gazebo
              camera plugin to publish the camera frame at the higher
              rate of 10hz, while maintaining the physics rate. -->
              <width>711</width>
              <height>400</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.02</near>
            <far>300</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <!-- Noise is sampled independently per pixel on each frame.
                That pixel's noise value is added to each of its color
                channels, which at that point lie in the range [0,1]. -->
            <mean>0.0</mean>
            <stddev>0.02</stddev>
          </noise>
        </camera>
        <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
          <alwaysOn>true</alwaysOn>
          <updateRate>0.0</updateRate>
          <cameraName>/camera/color</cameraName>
          <imageTopicName>image_raw</imageTopicName>
          <cameraInfoTopicName>camera_info</cameraInfoTopicName>
          <frameName>camera_link</frameName>
          <hackBaseline>0.07</hackBaseline>
          <distortionK1>0.0</distortionK1>
          <distortionK2>0.0</distortionK2>
          <distortionK3>0.0</distortionK3>
          <distortionT1>0.0</distortionT1>
          <distortionT2>0.0</distortionT2>
        </plugin>
      </sensor>
    </link>
    
    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
      <axis>
        <xyz>0 0 2</xyz>
      </axis>
    </joint>

<!-- 两个轮子 -->
    <link name="wheel_r">
      <pose>-0.165 -0.225 0.125 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00222</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00391</iyy>
          <iyz>0</iyz>
          <izz>0.00222</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.125</radius><length>0.08</length></cylinder></geometry>
        <pose>0 0 0 0 1.571 1.571</pose>
        <surface>
          <contact>
            <ode>
              <kp>1e7</kp>
              <kd>1</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100000</mu>
              <mu2>10</mu2>
              <fdir1>1 0 0</fdir1>
              <slip1>0</slip1>
              <slip2>0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
          <geometry>
            <mesh>
              <uri>model://cs_rover_charge/meshes/lunzi.dae</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
      </visual>
    </link>

    <joint name="joint_wheel_r" type="revolute">
      <parent>base_link</parent>
      <child>wheel_r</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <link name="wheel_l">
      <pose>-0.165 0.225 0.125 0 0 3.1416</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00222</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00391</iyy>
          <iyz>0</iyz>
          <izz>0.00222</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.125</radius><length>0.08</length></cylinder></geometry>
        <pose>0 0 0 0 1.571 1.571</pose>
        <surface>
          <contact>
            <ode>
              <kp>1e7</kp>
              <kd>1</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100000</mu>
              <mu2>10</mu2>
              <fdir1>1 0 0</fdir1>
              <slip1>0</slip1>
              <slip2>0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
          <geometry>
            <mesh>
              <uri>model://cs_rover_charge/meshes/lunzi.dae</uri>
              <scale>1 1 1</scale> <!-- 这里调整缩放 -->
            </mesh>
          </geometry>
      </visual>
    </link>

    <joint name="joint_wheel_l" type="revolute">
      <parent>base_link</parent>
      <child>wheel_l</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <link name="front_wheel_l">
      <pose>0.266 0.225 0.125 0 0 3.1415926</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00222</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00391</iyy>
          <iyz>0</iyz>
          <izz>0.00222</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.125</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <pose>0 0 0 0 1.571 1.571</pose>
        <surface>
          <contact>
            <ode>
              <kp>1e7</kp>
              <kd>1</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100000</mu>
              <mu2>10</mu2>
              <fdir1>1 0 0</fdir1>
              <slip1>0</slip1>
              <slip2>0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
          <geometry>
            <mesh>
              <uri>model://cs_rover_charge/meshes/lunzi.dae</uri>
              <scale>1 1 1</scale> <!-- 这里调整缩放 -->
            </mesh>
          </geometry>
      </visual>

    </link>


    <joint name="joint_front_wheel_l" type="revolute">
      <parent>base_link</parent>
      <child>front_wheel_l</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <!-- 右前隐形小轮 -->
    <link name="front_wheel_r">
      <pose>0.266 -0.225 0.125 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00222</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00391</iyy>
          <iyz>0</iyz>
          <izz>0.00222</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.125</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <pose>0 0 0 0 1.571 1.571</pose>
        <surface>
          <contact>
            <ode>
              <kp>1e7</kp>
              <kd>1</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100000</mu>
              <mu2>10</mu2>
              <fdir1>1 0 0</fdir1>
              <slip1>0</slip1>
              <slip2>0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
          <geometry>
            <mesh>
              <uri>model://cs_rover_charge/meshes/lunzi.dae</uri>
              <scale>1 1 1</scale> 
            </mesh>
          </geometry>
      </visual>

    </link>

    <joint name="joint_front_wheel_r" type="revolute">
      <parent>base_link</parent>
      <child>front_wheel_r</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

<!-- ardupilot配置-->
    <plugin name="ardurover_plugin" filename="libArduPilotPlugin.so">
      <fdm_addr>127.0.0.1</fdm_addr>
      <fdm_port_in>9002</fdm_port_in>
      <fdm_port_out>9003</fdm_port_out>
      <imuName>imu_link::imu_sensor</imuName>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
      <modelXYZToAirplaneXForwardZDown>0 0 0 3.141593 0 0</modelXYZToAirplaneXForwardZDown>
      <gazeboXYZToNED>0 0 0 3.141593 0 0</gazeboXYZToNED>

      <control channel="0">
        <jointName>joint_wheel_l</jointName>
        <useForce>1</useForce>
        <multiplier>-50</multiplier>   <!-- PWM 转速度比例，可以调大/调小 -->
        <offset>-0.5</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>1</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0.0001</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>10.0</cmd_max>       <!-- 最大角速度 rad/s -->
        <cmd_min>-10.0</cmd_min>
      </control>

      <control channel="0">
        <jointName>joint_front_wheel_l</jointName>
        <useForce>1</useForce>
        <multiplier>-50</multiplier>   <!-- PWM 转速度比例，可以调大/调小 -->
        <offset>-0.5</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>1</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0.0001</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>10.0</cmd_max>       <!-- 最大角速度 rad/s -->
        <cmd_min>-10.0</cmd_min>
      </control>

      <!-- 右轮驱动 -->
      <control channel="2">
        <jointName>joint_wheel_r</jointName>
        <useForce>1</useForce>
        <multiplier>50</multiplier>
        <offset>-0.5</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>1</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0.0001</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>10.0</cmd_max>
        <cmd_min>-10.0</cmd_min>
      </control>

      <control channel="2">
        <jointName>joint_front_wheel_r</jointName>
        <useForce>1</useForce>
        <multiplier>50</multiplier>
        <offset>-0.5</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>1</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0.0001</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>10.0</cmd_max>
        <cmd_min>-10.0</cmd_min>
      </control>

    </plugin>

  </model>
</sdf>
